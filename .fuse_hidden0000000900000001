<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">⚡ Takes under 5 minutes</div>
  <h1>Three steps to knowing<br>exactly <em>what you're buying</em></h1>
  <p class="hero-sub">Drop your legal pack in, paste the listing URL, wait a few minutes. That's it — full risk report, plain English, no solicitor required.</p>
  <div class="hero-badges">
    <span class="hero-badge">📄 ZIP or PDF, any size</span>
