<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --purple:#6d28d9;--purple2:#7c3aed;--purplebg:#f5f0ff;--purplemid:#ddd6fe;--purpledeep:#3b0f8c;
  --t1:#0d0c1a;--t2:#4a4863;--t3:#9490b0;--bg:#f8f7ff;--b1:#e2e0f0;
  --red:#dc2626;--redbg:#fef2f2;--redmid:#fecaca;
  --amber:#d97706;--amberbg:#fffbeb;
  --ok:#15803d;--okbg:#f0fdf4;--okmid:#dcfce7;
  --surface:#ffffff;
}
html{font-size:16px;scroll-behavior:smooth}
body{background:var(--bg);color:var(--t1);font-family:'DM Sans',sans-serif;-webkit-font-smoothing:antialiased;}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,0.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--b1);padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;}
.nav-logo{display:flex;align-items:center;gap:9px;font-size:16px;font-weight:800;color:var(--t1);letter-spacing:-0.4px;text-decoration:none;}
.nav-logo-icon{width:30px;height:30px;background:var(--purple);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.nav-links{display:flex;align-items:center;gap:24px;}
.nav-links a{font-size:13px;font-weight:600;color:var(--t2);text-decoration:none;transition:color 0.15s;}
.nav-links a:hover,.nav-links a.active{color:var(--purple);}
.nav-cta{padding:9px 20px;background:var(--purple);color:#fff;border-radius:9px;font-size:13px;font-weight:700;text-decoration:none;transition:all 0.15s;box-shadow:0 3px 12px rgba(109,40,217,0.3);}
.nav-cta:hover{background:var(--purpledeep);text-decoration:none;transform:translateY(-1px);}

/* HERO */
.hero{background:linear-gradient(160deg,#0d0c1a 0%,#1e0e5c 60%,#2d0f7a 100%);padding:80px 24px 72px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(109,40,217,0.07) 1px,transparent 1px),linear-gradient(90deg,rgba(109,40,217,0.07) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:7px;font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:#c4b5fd;margin-bottom:20px;padding:5px 14px;border-radius:20px;border:1px solid rgba(196,181,253,0.3);background:rgba(109,40,217,0.2);}
.hero h1{font-size:58px;font-weight:800;letter-spacing:-3px;line-height:1.0;color:#fff;margin-bottom:18px;}
.hero h1 em{color:#c4b5fd;font-style:italic;font-family:'Instrument Serif',serif;font-weight:400;letter-spacing:-1px;}
.hero-sub{font-size:18px;color:rgba(255,255,255,0.65);line-height:1.7;max-width:540px;margin:0 auto 36px;}
.hero-badges{display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap;}
.hero-badge{font-size:12.5px;color:rgba(255,255,255,0.5);font-family:'DM Mono',monospace;display:flex;align-items:center;gap:6px;}
.hero-badge-sep{width:4px;height:4px;background:rgba(255,255,255,0.2);border-radius:50%;}

/* STEPS */
.steps-section{max-width:860px;margin:0 auto;padding:72px 24px 80px;}
.steps-label{text-align:center;font-size:11px;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;color:var(--purple);margin-bottom:12px;font-family:'DM Mono',monospace;}
.steps-headline{text-align:center;font-size:38px;font-weight:800;letter-spacing:-1.8px;line-height:1.1;color:var(--t1);margin-bottom:8px;}
.steps-headline em{color:var(--purple);font-style:italic;font-family:'Instrument Serif',serif;font-weight:400;}
.steps-sub{text-align:center;font-size:16px;color:var(--t3);margin-bottom:56px;line-height:1.6;}

.steps-list{display:flex;flex-direction:column;gap:16px;}

.step{background:var(--surface);border:1px solid var(--b1);border-radius:20px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;}
.step:hover{box-shadow:0 12px 40px rgba(109,40,217,0.1);transform:translateY(-2px);}

.step-header{display:flex;align-items:center;gap:20px;padding:28px 32px 20px;}
.step-badge{width:48px;height:48px;border-radius:13px;background:linear-gradient(135deg,var(--purple),#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:#fff;font-family:'DM Mono',monospace;flex-shrink:0;box-shadow:0 4px 14px rgba(109,40,217,0.35);}
.step-meta{flex:1;}
.step-num-label{font-size:10.5px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--purple);font-family:'DM Mono',monospace;margin-bottom:3px;}
.step-title{font-size:22px;font-weight:800;letter-spacing:-0.6px;color:var(--t1);}
.step-time{font-size:11.5px;font-family:'DM Mono',monospace;color:var(--t3);margin-top:3px;}

.step-body-text{padding:0 32px 20px;font-size:15.5px;color:var(--t2);line-height:1.72;}

/* STEP MOCKUPS */
.step-mockup{margin:0 32px 28px;border-radius:14px;overflow:hidden;border:1px solid var(--b1);}

/* Upload mockup */
.upload-mockup{background:#fafafa;padding:32px;display:flex;flex-direction:column;align-items:center;justify-content:center;border:2px dashed var(--purplemid);border-radius:14px;margin:0 32px 28px;gap:10px;transition:border-color 0.2s;}
.upload-icon{font-size:36px;}
.upload-title{font-size:16px;font-weight:700;color:var(--t1);}
.upload-hint{font-size:13px;color:var(--t3);}
.upload-types{display:flex;gap:7px;margin-top:4px;flex-wrap:wrap;justify-content:center;}
.upload-type{font-size:11.5px;font-weight:700;padding:3px 11px;border-radius:6px;border:1px solid var(--b1);color:var(--t2);background:#fff;}
.upload-type.active{border-color:var(--purple);color:var(--purple);background:var(--purplebg);}

/* URL mockup */
.url-mockup{background:#fafafa;padding:20px 24px;border-radius:14px;margin:0 32px 28px;border:1px solid var(--b1);}
.url-mockup-label{font-size:11px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:var(--t3);font-family:'DM Mono',monospace;margin-bottom:10px;}
.url-input-row{display:flex;gap:10px;align-items:center;}
.url-input-fake{flex:1;background:#fff;border:1.5px solid var(--b1);border-radius:9px;padding:10px 14px;font-size:13.5px;color:var(--t3);font-family:'DM Mono',monospace;display:flex;align-items:center;gap:8px;}
.url-input-fake span{color:var(--t2);}
.url-tag{font-size:10.5px;font-weight:700;padding:3px 10px;background:#f0fdf4;border:1px solid var(--okmid);color:var(--ok);border-radius:6px;white-space:nowrap;}
.url-hint-row{margin-top:8px;font-size:12px;color:var(--t3);display:flex;align-items:center;gap:6px;}
.url-autofill-chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.autofill-chip{font-size:11.5px;padding:3px 10px;border-radius:20px;background:var(--purplebg);border:1px solid var(--purplemid);color:var(--purple);font-weight:600;}

/* Progress mockup */
.progress-mockup{background:#0d0c1a;border-radius:14px;margin:0 32px 28px;padding:24px 28px;border:1px solid rgba(109,40,217,0.3);}
.progress-topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.progress-title{font-size:13px;font-weight:700;color:#fff;}
.progress-timer{font-size:12px;font-family:'DM Mono',monospace;color:#c4b5fd;}
.progress-stages{display:flex;flex-direction:column;gap:10px;}
.progress-stage{display:flex;align-items:center;gap:12px;}
.progress-dot{width:20px;height:20px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;}
.progress-dot.done{background:#22c55e;}
.progress-dot.active{background:var(--purple);animation:pulse-dot 1.2s ease-in-out infinite;}
.progress-dot.waiting{background:rgba(255,255,255,0.1);}
.progress-stage-label{font-size:13px;color:rgba(255,255,255,0.7);}
.progress-stage-label.done{color:#86efac;}
.progress-stage-label.active{color:#fff;font-weight:600;}
.progress-bar-wrap{height:3px;background:rgba(255,255,255,0.1);border-radius:2px;margin-top:18px;overflow:hidden;}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(--purple),#a78bfa);border-radius:2px;width:65%;animation:progress-anim 3s ease-in-out infinite alternate;}

/* Report mockup */
.report-mockup{background:#fff;border-radius:14px;margin:0 32px 28px;overflow:hidden;border:1px solid var(--b1);}
.report-topbar{background:linear-gradient(90deg,var(--purpledeep),var(--purple));padding:14px 20px;display:flex;align-items:center;justify-content:space-between;}
.report-topbar-title{font-size:13px;font-weight:700;color:#fff;}
.report-verdict-chip{font-size:11px;font-weight:800;padding:3px 10px;border-radius:6px;background:rgba(220,38,38,0.25);color:#fca5a5;border:1px solid rgba(220,38,38,0.4);}
.report-body{padding:16px 20px;display:flex;flex-direction:column;gap:10px;}
.report-flag{border-radius:9px;padding:10px 14px;border-left:3px solid;}
.report-flag.crit{background:var(--redbg);border-color:var(--red);}
.report-flag.warn{background:var(--amberbg);border-color:var(--amber);}
.report-flag.ok{background:var(--okbg);border-color:var(--ok);}
.flag-sev{font-size:9.5px;font-weight:800;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:3px;}
.report-flag.crit .flag-sev{color:var(--red);}
.report-flag.warn .flag-sev{color:var(--amber);}
.report-flag.ok .flag-sev{color:var(--ok);}
.flag-label{font-size:13.5px;font-weight:700;color:var(--t1);}
.flag-source{font-size:11px;color:var(--t3);font-family:'DM Mono',monospace;margin-top:3px;}

/* CONNECTOR */
.step-connector{text-align:center;color:var(--b1);font-size:28px;line-height:1;padding:4px 0;}

/* CTA */
.cta-section{background:linear-gradient(135deg,var(--purpledeep) 0%,#1e0e5c 100%);padding:72px 24px;text-align:center;}
.cta-inner{max-width:580px;margin:0 auto;}
.cta-eyebrow{font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:#c4b5fd;margin-bottom:16px;font-family:'DM Mono',monospace;}
.cta-h2{color:#fff;font-size:38px;font-weight:800;letter-spacing:-1.8px;line-height:1.1;margin-bottom:16px;}
.cta-h2 em{color:#c4b5fd;font-style:italic;font-family:'Instrument Serif',serif;font-weight:400;}
.cta-sub{color:rgba(255,255,255,0.65);font-size:17px;line-height:1.7;margin-bottom:32px;}
.cta-btn{display:inline-block;padding:17px 44px;background:#fff;color:var(--purpledeep);border-radius:12px;font-weight:800;font-size:17px;text-decoration:none;box-shadow:0 4px 24px rgba(0,0,0,0.25);transition:all 0.15s;}
.cta-btn:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(0,0,0,0.3);text-decoration:none;color:var(--purpledeep);}
.cta-note{color:rgba(255,255,255,0.35);font-size:12px;margin-top:16px;font-family:'DM Mono',monospace;}

/* FOOTER */
footer{background:var(--surface);border-top:1px solid var(--b1);padding:28px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
footer p{font-size:12px;color:var(--t3);font-family:'DM Mono',monospace;}
.footer-links{display:flex;gap:20px;}
.footer-links a{font-size:12px;color:var(--t3);text-decoration:none;}
.footer-links a:hover{color:var(--purple);}
.footer-tools{width:100%;border-top:1px solid var(--b1);margin-top:12px;padding-top:14px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
.footer-tools-label{font-size:11px;font-weight:800;letter-spacing:0.8px;text-transform:uppercase;color:var(--t3);font-family:'DM Mono',monospace;flex-shrink:0;}
.footer-tools a{font-size:12px;color:var(--t3);text-decoration:none;}
.footer-tools a:hover{color:var(--purple);}

@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.7;transform:scale(0.85);}}
@keyframes progress-anim{0%{width:55%}100%{width:78%}}

@media(max-width:640px){
  nav{padding:0 20px;}
  .nav-links{display:none;}
  .hero h1{font-size:38px;letter-spacing:-2px;}
  .steps-headline{font-size:28px;letter-spacing:-1px;}
  .step-header{padding:20px 20px 14px;}
  .step-body-text{padding:0 20px 16px;}
  .upload-mockup,.step-mockup,.url-mockup,.progress-mockup,.report-mockup{margin-left:20px;margin-right:20px;}
  footer{flex-direction:column;text-align:center;padding:24px;}
}
</style>
